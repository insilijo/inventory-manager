# Copy to .env in this directory; python-dotenv will load it on startup.
# .env is gitignored, so secrets stay local.

ANTHROPIC_API_KEY=sk-ant-...

# Twilio token is only needed if you set VALIDATE_TWILIO=true.
TWILIO_AUTH_TOKEN=

# false = skip Twilio signature checks (use for local dev / simulator)
# true  = require valid Twilio signatures on /sms (production)
VALIDATE_TWILIO=false

# Admin credentials for /admin, /simulator, and admin API endpoints.
ADMIN_USER=admin
ADMIN_PASSWORD=devpass

# Required only when VALIDATE_TWILIO=true; pick a long random string.
SESSION_SECRET=
