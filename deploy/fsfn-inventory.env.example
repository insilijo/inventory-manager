# Copy to /etc/fsfn-inventory.env on the server, then `chmod 600`.
# Fill in real values before starting the service.

ANTHROPIC_API_KEY=sk-ant-...
TWILIO_AUTH_TOKEN=...
VALIDATE_TWILIO=true

# Admin HTTP Basic credentials (used for /admin and admin-write endpoints).
ADMIN_USER=admin
ADMIN_PASSWORD=replace-me-with-a-long-random-string

# Persistent SQLite location (matches ReadWritePaths in the systemd unit).
DB_PATH=/var/lib/fsfn-inventory/inventory.db
